	</xs:element>
	<xs:element name="ERKLAERUNG">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="ALLGEMEINE_DATEN"/>
				<xs:element ref="WEGBUCHUNG" minOccurs="0" maxOccurs="7"/>
				<xs:element ref="UEBERTRAGENDER_BETRAG" minOccurs="0"/>
				<xs:element ref="ZUBUCHUNG" minOccurs="0" maxOccurs="7"/>
			</xs:sequence>
			<xs:attribute name="art" type="xs:string" use="required"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="ERKLAERUNGS_UEBERMITTLUNG">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="INFO_DATEN"/>
