{
  "name": "fon-api",
  "version": "0.0.0",
  "description": "TypeScript SDK for the Austrian FinanzOnline (BMF) SOAP web services — session, abfrage-datenuebermittlung, and unified fileupload submission with per-year typed payloads.",
  "type": "module",
  "license": "MIT",
  "author": "Florian Rauscha",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "fon-api": "./dist/cli/index.js",
    "fon-api-mcp": "./dist/mcp/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
